# ============================================
#  THD EDU QUIZ - CẤU HÌNH CHUNG
#  Dùng cho cả Frontend (React) và Backend (Node.js)
#  Copy file này thành .env rồi chỉnh sửa giá trị
# ============================================

# ===== FRONTEND (React) =====
# Để trống/xóa dòng = tự động detect URL backend
# Dev: dùng hostname hiện tại + port 4000
# Production: dùng /api
# REACT_APP_API_BASE_URL=http://localhost:4000

# ===== DATABASE (MySQL) =====
# Dev (XAMPP):
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=quiz_website
# Production: dùng DATABASE_URL
# DATABASE_URL=mysql://user:password@host:3306/database

# ===== SERVER =====
JWT_SECRET=thd_edu_quiz_2024_secret_key
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
BACKEND_PORT=4000

# ===== COOKIE (chỉ cần set khi production) =====
# COOKIE_DOMAIN=.yourdomain.com

# ===== GEMINI AI (tạo Quiz tự động) =====
GEMINI_API_KEY=your_gemini_api_key_here

# ===== SMTP (gửi mail quên mật khẩu) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="THD EDU QUIZ <your-email@gmail.com>"
SMTP_TLS_REJECT_UNAUTHORIZED=true

# ===== OTP =====
OTP_TTL_SECONDS=600
OTP_THROTTLE_SECONDS=60
OTP_MAX_ATTEMPTS=5

# ===== PRODUCTION ONLY =====
# DOCUMENTS_DIR=../documents
# BASE_PATH=/api
